# Application
APP_NAME=志愿汇
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Database
DB_CONNECTION=postgresql
DB_HOST=database
DB_PORT=5432
DB_DATABASE=volunteer_db_dev
DB_USERNAME=postgres
DB_PASSWORD=password123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Backend
BACKEND_HOST=localhost
BACKEND_PORT=8080
API_BASE_URL=http://localhost:8080/api/v1

# Frontend
FRONTEND_HOST=localhost
FRONTEND_PORT=3000

# JWT
JWT_SECRET=dev_secret_key_for_testing_only
JWT_EXPIRATION=86400000

# WeChat (Development)
WECHAT_APP_ID=your_dev_wechat_app_id
WECHAT_APP_SECRET=your_dev_wechat_app_secret

# Email (Development)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@localhost
MAIL_FROM_NAME=志愿汇

# SMS (Development - Mock)
SMS_ACCESS_KEY=dev_access_key
SMS_SECRET_KEY=dev_secret_key
SMS_SIGN_NAME=志愿汇
SMS_TEMPLATE_CODE=dev_template

# Storage
STORAGE_TYPE=local
STORAGE_PATH=/storage

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Monitoring (Development)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Performance
CACHE_DRIVER=redis
QUEUE_CONNECTION=sync
SESSION_DRIVER=redis

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_ATTEMPTS=100
RATE_LIMIT_DECAY=60

# Upload
MAX_UPLOAD_SIZE=20971520
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Timezone
APP_TIMEZONE=Asia/Shanghai

# Locale
APP_LOCALE=zh_CN