# Application
APP_NAME=志愿汇
APP_ENV=production
APP_DEBUG=false
APP_URL=https://volunteer-system.com

# Database
DB_CONNECTION=postgresql
DB_HOST=database
DB_PORT=5432
DB_DATABASE=volunteer_db
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Backend
BACKEND_HOST=backend
BACKEND_PORT=8080
API_BASE_URL=https://volunteer-system.com/api/v1

# Frontend
FRONTEND_HOST=frontend
FRONTEND_PORT=80

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# WeChat
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# Email
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@volunteer-system.com
MAIL_FROM_NAME=志愿汇

# SMS
SMS_ACCESS_KEY=your_sms_access_key
SMS_SECRET_KEY=your_sms_secret_key
SMS_SIGN_NAME=志愿汇
SMS_TEMPLATE_CODE=your_template_code

# Storage
STORAGE_TYPE=local
STORAGE_PATH=/storage

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=info

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Performance
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Security
CORS_ALLOWED_ORIGINS=https://volunteer-system.com,https://www.volunteer-system.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ATTEMPTS=60
RATE_LIMIT_DECAY=60

# Upload
MAX_UPLOAD_SIZE=20971520
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Timezone
APP_TIMEZONE=Asia/Shanghai

# Locale
APP_LOCALE=zh_CN