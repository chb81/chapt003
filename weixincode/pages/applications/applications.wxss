.applications-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 120rpx;
}

.tabs-section {
  background: #ffffff;
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tabs-scroll {
  display: flex;
  white-space: nowrap;
  padding: 0 30rpx;
}

.tab-item {
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  background: #f5f7fa;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
}

.tab-item.active {
  background: #1989fa;
  color: #ffffff;
  font-weight: bold;
}

.applications-list {
  padding: 20rpx 30rpx;
}

.application-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.app-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
  line-height: 1.4;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  white-space: nowrap;
}

.status-DRAFT {
  background: #fff7e6;
  color: #faad14;
}

.status-SUBMITTED {
  background: #f6ffed;
  color: #52c41a;
}

.status-SIMULATION {
  background: #e6f7ff;
  color: #1989fa;
}

.card-body {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #999;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  background: #f5f7fa;
  color: #666;
}

.action-btn.primary {
  background: #1989fa;
  color: #ffffff;
}

.action-btn.danger {
  background: #fef0f0;
  color: #ee0a24;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #1989fa;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

.create-btn-wrap {
  position: fixed;
  bottom: 120rpx;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  z-index: 10;
}

.create-btn {
  background: #1989fa;
  color: #ffffff;
  text-align: center;
  padding: 24rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 20rpx rgba(25, 137, 250, 0.4);
}
