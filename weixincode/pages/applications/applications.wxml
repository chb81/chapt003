<view class="applications-container">
  <view class="tabs-section">
    <scroll-view class="tabs-scroll" scroll-x enable-flex>
      <view 
        wx:for="{{tabs}}" 
        wx:key="value"
        class="tab-item {{activeTab === item.value ? 'active' : ''}}" 
        bindtap="onTabChange"
        data-tab="{{item.value}}"
      >
        {{item.label}}
      </view>
    </scroll-view>
  </view>

  <view class="applications-list">
    <view 
      wx:for="{{filteredApplications}}" 
      wx:key="id" 
      class="application-card"
    >
      <view class="card-header">
        <view class="app-name">{{item.simulationName || item.name || ('志愿方案 #' + item.id)}}</view>
        <view class="status-badge status-{{item.status}}">
          {{item.status === 'DRAFT' ? '草稿' : (item.status === 'SUBMITTED' ? '已提交' : '模拟方案')}}
        </view>
      </view>
      
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">年份</text>
          <text class="info-value">{{item.year || '--'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">学校数量</text>
          <text class="info-value">{{item.itemCount || 0}}所</text>
        </view>
        <view class="info-row">
          <text class="info-label">创建时间</text>
          <text class="info-value">{{item.createdAt}}</text>
        </view>
        <view wx:if="{{item.submittedAt}}" class="info-row">
          <text class="info-label">提交时间</text>
          <text class="info-value">{{item.submittedAt}}</text>
        </view>
      </view>
      
      <view class="card-footer">
        <view class="action-btn" catchtap="onViewDetail" data-id="{{item.id}}">查看详情</view>
        <view wx:if="{{item.status === 'DRAFT'}}" class="action-btn primary" catchtap="onSubmitApplication" data-id="{{item.id}}">提交</view>
        <view wx:if="{{item.status !== 'SUBMITTED'}}" class="action-btn danger" catchtap="onDeleteApplication" data-id="{{item.id}}">删除</view>
      </view>
    </view>

    <view wx:if="{{filteredApplications.length === 0 && !loading}}" class="empty-state">
      <view class="empty-text">暂无志愿方案</view>
      <view class="empty-hint">去查看学校列表，创建志愿方案吧</view>
    </view>

    <view wx:if="{{loading}}" class="loading-state">
      <view class="loading-spinner"></view>
      <view class="loading-text">加载中...</view>
    </view>
  </view>

  <view class="create-btn-wrap">
    <view class="create-btn" bindtap="onCreateNew">+ 创建新方案</view>
  </view>

  <view class="tools-section">
    <view class="tools-title">方案工具</view>
    <view class="tools-grid">
      <view class="tool-item" bindtap="goToRiskAssessment">
        <view class="tool-icon">🛡️</view>
        <view class="tool-name">风险评估</view>
      </view>
      <view class="tool-item" bindtap="goToPlanComparison">
        <view class="tool-icon">⚖️</view>
        <view class="tool-name">方案对比</view>
      </view>
      <view class="tool-item" bindtap="goToScoreRank">
        <view class="tool-icon">📊</view>
        <view class="tool-name">位次换算</view>
      </view>
    </view>
  </view>
</view>
