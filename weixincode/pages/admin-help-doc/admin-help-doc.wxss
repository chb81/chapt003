@import '../admin-allocation-quota/admin-allocation-quota.wxss';
.status-tag { font-size: 24rpx; padding: 4rpx 12rpx; border-radius: 6rpx; }
.status-tag.published { color: #52c41a; background: #f6ffed; }
.status-tag.unpublished { color: #faad14; background: #fffbe6; }
.btn-toggle { color: #722ed1; font-size: 26rpx; padding: 8rpx 24rpx; }
.form-textarea { padding: 16rpx 20rpx; background: #f5f6f8; border-radius: 8rpx; font-size: 28rpx; color: #333; width: 100%; box-sizing: border-box; min-height: 120rpx; }
.picker-val { display: flex; justify-content: space-between; align-items: center; }
.form-switch-row { display: flex; justify-content: space-between; align-items: center; }
