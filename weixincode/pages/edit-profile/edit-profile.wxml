<view class="container">
  <view class="header">
    <view class="title">编辑个人资料</view>
  </view>

  <scroll-view scroll-y class="content">
    <view class="avatar-section">
      <view class="avatar-wrapper" bindtap="chooseAvatar">
        <image 
          class="avatar-image" 
          src="{{form.avatarUrl || '/images/default-avatar.png'}}" 
          mode="aspectFill"
        ></image>
        <view class="avatar-mask">
          <view class="edit-icon">📷</view>
          <view class="edit-text">点击更换</view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">基本信息</view>
      
      <view class="form-item required">
        <view class="form-label">昵称</view>
        <input 
          class="form-input" 
          placeholder="请输入昵称"
          value="{{form.nickname}}"
          bindinput="handleNicknameInput"
          maxlength="20"
        />
      </view>

      <view class="form-item">
        <view class="form-label">真实姓名</view>
        <input 
          class="form-input" 
          placeholder="请输入真实姓名"
          value="{{form.realName}}"
          bindinput="handleRealNameInput"
          maxlength="10"
        />
      </view>

      <view class="form-item">
        <view class="form-label">性别</view>
        <view class="form-select" bindtap="showGenderPicker">
          <view class="select-value">{{form.gender || '请选择'}}</view>
          <view class="select-arrow">▼</view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">生日</view>
        <view class="form-select" bindtap="showDatePicker">
          <view class="select-value">{{form.birthday || '请选择'}}</view>
          <view class="select-arrow">▼</view>
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">联系方式</view>
      
      <view class="form-item">
        <view class="form-label">手机号</view>
        <input 
          class="form-input" 
          type="number"
          placeholder="请输入手机号"
          value="{{form.phone}}"
          bindinput="handlePhoneInput"
          maxlength="11"
        />
      </view>

      <view class="form-item">
        <view class="form-label">邮箱</view>
        <input 
          class="form-input" 
          type="text"
          placeholder="请输入邮箱"
          value="{{form.email}}"
          bindinput="handleEmailInput"
        />
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">其他信息</view>
      
      <view class="form-item">
        <view class="form-label">身份证号</view>
        <input 
          class="form-input" 
          type="idcard"
          placeholder="请输入身份证号"
          value="{{form.idCard}}"
          bindinput="handleIdCardInput"
          maxlength="18"
        />
      </view>

      <view class="form-item">
        <view class="form-label">地址</view>
        <textarea 
          class="form-textarea" 
          placeholder="请输入地址"
          value="{{form.address}}"
          bindinput="handleAddressInput"
          maxlength="100"
          show-confirm-bar="{{false}}"
        ></textarea>
      </view>
    </view>

    <view class="tips-section">
      <view class="tips-title">温馨提示</view>
      <view class="tips-item">• 真实姓名和身份证号用于实名认证</view>
      <view class="tips-item">• 手机号和邮箱可用于找回密码</view>
      <view class="tips-item">• 所有信息都将严格保密</view>
    </view>

    <view class="button-section">
      <button class="btn-cancel" bindtap="handleCancel">取消</button>
      <button class="btn-save" bindtap="saveProfile" disabled="{{submitting}}">
        {{submitting ? '保存中...' : '保存'}}
      </button>
    </view>
  </scroll-view>

  <picker 
    mode="selector" 
    range="{{genderOptions}}" 
    value="{{genderOptions.indexOf(form.gender)}}" 
    bindchange="handleGenderChange"
    wx:if="{{showGenderPicker}}"
  >
  </picker>

  <picker 
    mode="date" 
    value="{{form.birthday}}" 
    end="{{currentDate}}"
    bindchange="handleDateChange"
    wx:if="{{showDatePicker}}"
  >
  </picker>
</view>
