page {
  background-color: #f5f5f5;
}

.container {
  height: 100vh;
}

.content {
  padding: 40rpx 30rpx;
  background: #fff;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.update-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.section {
  margin-bottom: 60rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.list-item {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  padding-left: 20rpx;
  margin-bottom: 10rpx;
}

.footer {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 80rpx;
  padding-top: 40rpx;
  border-top: 1rpx solid #f0f0f0;
}
