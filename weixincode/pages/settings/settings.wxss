page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding-bottom: 40rpx;
}

.header {
  background: #fff;
  padding: 40rpx 30rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.settings-section {
  background: #fff;
  margin-top: 20rpx;
}

.section-title {
  padding: 20rpx 30rpx;
  font-size: 24rpx;
  color: #999;
  background: #fafafa;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.3s;
}

.setting-item:active {
  background-color: #f5f5f5;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.setting-value {
  font-size: 26rpx;
  color: #999;
  margin-left: 20rpx;
}

switch {
  transform: scale(0.8);
}

.footer {
  padding: 40rpx 30rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #ccc;
}
