page {
  background-color: #f5f7fa;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.plan-selector {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  font-size: 20rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.loading {
  text-align: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.risk-overview {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 12rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.risk-badge {
  font-size: 32rpx;
  font-weight: 700;
  padding: 12rpx 32rpx;
  border-radius: 48rpx;
}

.risk-level-LOW {
  background: #f6ffed;
  color: #52c41a;
}

.risk-level-MEDIUM {
  background: #fffbe6;
  color: #faad14;
}

.risk-level-HIGH {
  background: #fff2f0;
  color: #ff4d4f;
}

.risk-score {
  display: flex;
  align-items: baseline;
}

.score-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
}

.score-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #333;
}

.score-max {
  font-size: 26rpx;
  color: #999;
  margin-left: 4rpx;
}

.metrics-card {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.metric-item {
  width: 50%;
  padding: 16rpx 0;
  box-sizing: border-box;
}

.metric-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.metric-value {
  font-size: 36rpx;
  font-weight: 700;
}

.metric-value.safe {
  color: #52c41a;
}

.metric-value.warning {
  color: #faad14;
}

.metric-value.danger {
  color: #ff4d4f;
}

.schools-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.school-risk-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.school-risk-item:last-child {
  border-bottom: none;
}

.school-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.school-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.prob-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
}

.prob-high {
  background: #f6ffed;
  color: #52c41a;
}

.prob-medium {
  background: #fffbe6;
  color: #faad14;
}

.prob-low {
  background: #fff2f0;
  color: #ff4d4f;
}

.school-metrics {
  display: flex;
  gap: 30rpx;
}

.sm-item {
  flex: 1;
}

.sm-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.sm-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.advice-section {
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
  border-radius: 12rpx;
  padding: 30rpx;
}

.advice-text {
  font-size: 28rpx;
  color: #0050b3;
  line-height: 1.8;
}
