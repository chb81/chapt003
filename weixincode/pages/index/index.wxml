<view class="index-container">
  <view class="user-header">
    <view class="user-info">
      <view class="avatar-wrap">
        <view class="avatar-text">{{avatarLetter}}</view>
      </view>
      <view class="user-details">
        <view class="username">{{isLoggedIn ? (userInfo.nickname || userInfo.email || '用户') : '未登录'}}</view>
        <view wx:if="{{isLoggedIn}}" class="user-meta">
          <text class="meta-item">{{userInfo.email || ''}}</text>
        </view>
        <view wx:else class="auth-buttons">
          <view class="auth-btn" bindtap="onLogin">登录</view>
          <view class="auth-btn secondary" bindtap="onRegister">注册</view>
        </view>
      </view>
    </view>
  </view>

  <view class="stats-section">
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-value">{{stats.totalSchools}}</view>
        <view class="stat-label">学校总数</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.myApplications}}</view>
        <view class="stat-label">我的志愿</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.submittedCount}}</view>
        <view class="stat-label">已提交</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{stats.simulationCount}}</view>
        <view class="stat-label">模拟方案</view>
      </view>
    </view>
  </view>

  <view class="quick-actions-section">
    <view class="section-title">快捷功能</view>
    <view class="actions-grid">
      <view 
        wx:for="{{quickActions}}" 
        wx:key="label"
        class="action-item"
        bindtap="onQuickAction"
        data-url="{{item.url}}"
      >
        <view class="action-icon" style="background: {{item.color}}">
          <icon type="{{item.icon}}" size="24" color="#ffffff"></icon>
        </view>
        <view class="action-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="schools-section">
    <view class="section-header">
      <view class="section-title">热门学校</view>
      <view class="more-btn" bindtap="onAllSchools">查看全部 ></view>
    </view>
    
    <view class="schools-grid">
      <view 
        wx:for="{{featuredSchools}}" 
        wx:key="id"
        class="school-card"
        bindtap="onSchoolDetail"
        data-id="{{item.id}}"
      >
        <view class="school-info">
          <view class="school-name">{{item.name}}</view>
          <view class="school-meta">
            <text class="meta-text">{{item.city || ''}}</text>
            <text wx:if="{{item.district}}" class="meta-text">{{item.district}}</text>
          </view>
          <view class="school-type-tag">{{item.type === 'KEY_HIGH_SCHOOL' ? '重点高中' : (item.type === 'REGULAR_HIGH_SCHOOL' ? '普通高中' : '职业高中')}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{featuredSchools.length === 0 && !loading}}" class="empty-state">
      <view class="empty-text">暂无学校数据</view>
    </view>
  </view>

  <view wx:if="{{isLoggedIn && recentApplications.length > 0}}" class="applications-section">
    <view class="section-title">最近志愿</view>
    <view class="applications-list">
      <view 
        wx:for="{{recentApplications}}" 
        wx:key="id"
        class="application-item"
      >
        <view class="application-content">
          <view class="application-name">{{item.name || '志愿方案'}}</view>
          <view class="application-status">{{item.status === 'DRAFT' ? '草稿' : (item.status === 'SUBMITTED' ? '已提交' : '模拟')}}</view>
        </view>
        <view class="application-time">{{formatDate(item.createdAt)}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载中...</view>
  </view>

  <view class="bottom-space"></view>
</view>
