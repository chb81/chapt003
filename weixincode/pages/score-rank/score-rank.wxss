page {
  background-color: #f5f7fa;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.form-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.picker-value {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  font-size: 20rpx;
  color: #999;
  margin-left: 12rpx;
}

.action-btn {
  margin-bottom: 20rpx;
}

.my-rank-btn {
  margin-bottom: 40rpx;
}

.btn-primary {
  width: 100%;
  background: #1989fa;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border: none;
}

.btn-primary[disabled] {
  background: #b3d9ff;
}

.btn-secondary {
  width: 100%;
  background: #fff;
  color: #1989fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 20rpx 0;
  border: 2rpx solid #1989fa;
}

.result {
  margin-top: 20rpx;
}

.result-card {
  background: linear-gradient(135deg, #1989fa 0%, #096dd9 100%);
  border-radius: 12rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
}

.result-row {
  display: flex;
  align-items: center;
}

.result-item {
  flex: 1;
  text-align: center;
}

.result-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.result-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
}

.result-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.result-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.3);
}

.info-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.info-message {
  font-size: 26rpx;
  color: #faad14;
  line-height: 1.6;
}
