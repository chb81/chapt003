<view class="container">
  <view class="header">
    <view class="title">分数位次换算</view>
    <view class="subtitle">输入分数，换算全市排名和百分位</view>
  </view>

  <view class="form-card">
    <view class="form-row">
      <view class="form-label">总分</view>
      <input class="form-input" type="digit" placeholder="请输入中考总分" value="{{totalScore}}" bindinput="onScoreInput" />
    </view>
    <view class="form-row">
      <view class="form-label">城市</view>
      <picker mode="selector" range="{{cities}}" value="{{cityIndex}}" bindchange="onCityChange">
        <view class="picker-value">
          <text>{{cities[cityIndex] || '请选择城市'}}</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
    <view class="form-row">
      <view class="form-label">年份</view>
      <picker mode="selector" range="{{years}}" value="{{yearIndex}}" bindchange="onYearChange">
        <view class="picker-value">
          <text>{{years[yearIndex] || '请选择年份'}}</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="action-btn">
    <button class="btn-primary" bindtap="doConvert" disabled="{{!totalScore || converting}}">{{converting ? '换算中...' : '开始换算'}}</button>
  </view>

  <view class="my-rank-btn">
    <button class="btn-secondary" bindtap="getMyRank">使用我的成绩换算</button>
  </view>

  <view class="result" wx:if="{{rankData}}">
    <view class="result-card">
      <view class="result-row">
        <view class="result-item">
          <view class="result-label">全市排名</view>
          <view class="result-value highlight">{{rankData.rank}}</view>
          <view class="result-unit">名</view>
        </view>
        <view class="result-divider"></view>
        <view class="result-item">
          <view class="result-label">百分位</view>
          <view class="result-value highlight">{{rankData.percentile}}</view>
          <view class="result-unit">%</view>
        </view>
      </view>
    </view>

    <view class="info-card" wx:if="{{rankData.totalStudents}}">
      <view class="info-row">
        <text class="info-label">参考总人数</text>
        <text class="info-value">{{rankData.totalStudents}}人</text>
      </view>
    </view>

    <view class="info-card" wx:if="{{rankData.message}}">
      <view class="info-message">{{rankData.message}}</view>
    </view>
  </view>
</view>
