page {
  background-color: #f5f7fa;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.selector-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.selector-row {
  margin-bottom: 20rpx;
}

.selector-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  font-size: 20rpx;
  color: #999;
}

.vs-divider {
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1989fa;
  padding: 16rpx 0;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.compare-btn {
  margin-bottom: 30rpx;
}

.btn-primary {
  width: 100%;
  background: #1989fa;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border: none;
}

.btn-primary[disabled] {
  background: #b3d9ff;
  color: #fff;
}

.result {
  margin-top: 20rpx;
}

.recommendation {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 24rpx;
}

.rec-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.rec-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #d48806;
}

.compare-table {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.table-header {
  display: flex;
  background: #f5f7fa;
  padding: 20rpx;
}

.table-row {
  display: flex;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-row:last-child {
  border-bottom: none;
}

.th {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
}

.td {
  font-size: 28rpx;
  color: #333;
}

.col-label {
  flex: 1.2;
}

.col-value {
  flex: 1;
  text-align: center;
}

.td.winner {
  color: #1989fa;
  font-weight: 700;
}

.summary-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.summary-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}
