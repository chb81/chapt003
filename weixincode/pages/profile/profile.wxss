page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  padding: 30rpx 0;
}

.header-section {
  margin-bottom: 30rpx;
}

.user-info-card {
  background: linear-gradient(135deg, #1989fa 0%, #096dd9 100%);
  margin: 0 30rpx;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(25, 137, 250, 0.3);
}

.user-avatar {
  position: relative;
  margin-right: 24rpx;
}

.user-avatar image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.edit-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.user-details {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-phone {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 4rpx;
}

.user-id {
  font-size: 24rpx;
  opacity: 0.8;
}

.logout-btn {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 48rpx;
  font-size: 26rpx;
  backdrop-filter: blur(10rpx);
}

.login-card {
  background: linear-gradient(135deg, #1989fa 0%, #096dd9 100%);
  margin: 0 30rpx;
  padding: 80rpx 30rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(25, 137, 250, 0.3);
}

.login-icon {
  font-size: 96rpx;
  margin-bottom: 20rpx;
}

.login-text {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.login-tip {
  font-size: 26rpx;
  opacity: 0.9;
}

.stats-card {
  background: #fff;
  margin: 0 30rpx 30rpx;
  padding: 40rpx 30rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1989fa;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e8e8e8;
}

.menu-section {
  background: #fff;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.menu-title {
  padding: 30rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-list {
  padding: 0 30rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

.guest-section {
  margin: 0 30rpx;
}

.guest-tip {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #1989fa;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}
