<view class="container">
  <view class="header">
    <text class="title">绑定手机号</text>
    <text class="subtitle">绑定手机号后可享受更多服务</text>
  </view>
  
  <view class="content">
    <!-- 微信快捷获取手机号（推荐） -->
    <view class="quick-bind">
      <button class="wechat-phone-btn" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">
        微信快捷绑定
      </button>
    </view>

    <view class="divider">
      <view class="divider-line"></view>
      <text class="divider-text">手动输入</text>
      <view class="divider-line"></view>
    </view>

    <!-- 手动输入手机号验证 -->
    <view class="verify-form">
      <view class="form-item">
        <input 
          class="input" 
          placeholder="请输入手机号" 
          type="number"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>
      
      <view class="form-item code-item">
        <input 
          class="input code-input" 
          placeholder="请输入验证码" 
          type="text"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <button 
          class="send-btn" 
          bindtap="sendVerifyCode"
          disabled="{{countdown > 0}}"
        >
          {{countdown > 0 ? countdown + 's' : '获取验证码'}}
        </button>
      </view>
      
      <button class="verify-btn" bindtap="handleVerify" disabled="{{loading}}">
        {{loading ? '验证中...' : '确认绑定'}}
      </button>
    </view>
  </view>
</view>