page { background-color: #f5f6f8; }
.container { display: flex; flex-direction: column; height: 100vh; }
.session-info { background: #fff; padding: 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.info-row { display: flex; padding: 6rpx 0; font-size: 26rpx; }
.label { color: #999; width: 120rpx; }
.value { color: #333; }
.messages { flex: 1; overflow-y: auto; padding: 20rpx; }
.msg { margin-bottom: 20rpx; max-width: 80%; }
.msg.user { margin-right: auto; }
.msg.agent { margin-left: auto; }
.msg-header { display: flex; justify-content: space-between; margin-bottom: 6rpx; }
.msg-sender { font-size: 24rpx; color: #999; }
.msg-time { font-size: 22rpx; color: #ccc; }
.msg-content { padding: 16rpx 20rpx; border-radius: 12rpx; font-size: 28rpx; line-height: 1.5; }
.msg.user .msg-content { background: #fff; color: #333; }
.msg.agent .msg-content { background: #1890ff; color: #fff; }
.input-bar { display: flex; gap: 12rpx; padding: 16rpx 20rpx; background: #fff; border-top: 1rpx solid #f0f0f0; }
.msg-input { flex: 1; height: 72rpx; padding: 0 20rpx; background: #f5f6f8; border-radius: 36rpx; font-size: 28rpx; }
.send-btn { padding: 0 32rpx; background: #1890ff; border-radius: 36rpx; color: #fff; font-size: 28rpx; display: flex; align-items: center; }
.action-bar-bottom { padding: 12rpx 20rpx; background: #fff; }
.close-btn { text-align: center; padding: 16rpx; background: #ff4d4f; border-radius: 8rpx; color: #fff; font-size: 28rpx; }
