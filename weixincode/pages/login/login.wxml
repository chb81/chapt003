<view class="login-container">
  <!-- 顶部Logo区域 -->
  <view class="logo-section">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="app-name">中考志愿填报</text>
    <text class="app-slogan">智能填报，科学择校</text>
  </view>

  <!-- 微信一键登录（主按钮） -->
  <view class="wechat-login-section">
    <button 
      class="wechat-login-btn {{loading ? 'loading' : ''}}" 
      open-type="getUserInfo"
      bindgetuserinfo="handleWechatLogin"
      disabled="{{loading}}"
    >
      <image class="wechat-icon" src="/images/wechat-icon.png" mode="aspectFit"></image>
      <text wx:if="{{!loading}}">微信一键登录</text>
      <text wx:else>登录中...</text>
    </button>

    <view class="login-tip">
      <text>登录即代表同意</text>
      <text class="link" bindtap="goToTerms">《用户协议》</text>
      <text>和</text>
      <text class="link" bindtap="goToPrivacy">《隐私政策》</text>
    </view>
  </view>

  <!-- 分割线 -->
  <view class="divider">
    <view class="divider-line"></view>
    <text class="divider-text">其他登录方式</text>
    <view class="divider-line"></view>
  </view>

  <!-- 传统账号密码登录（降级方案，默认隐藏） -->
  <view class="traditional-login-section" wx:if="{{showTraditionalLogin}}">
    <view class="form-group">
      <view class="input-wrapper">
        <icon class="input-icon" type="person" size="16"></icon>
        <input 
          class="input-field" 
          type="text" 
          placeholder="请输入用户名/邮箱" 
          value="{{loginForm.username}}"
          data-field="username"
          bindinput="onInputChange"
        />
      </view>
    </view>

    <view class="form-group">
      <view class="input-wrapper">
        <icon class="input-icon" type="locked" size="16"></icon>
        <input 
          class="input-field" 
          type="password" 
          placeholder="请输入密码" 
          value="{{loginForm.password}}"
          data-field="password"
          bindinput="onInputChange"
        />
      </view>
    </view>

    <button 
      class="traditional-login-btn {{loading ? 'loading' : ''}}" 
      bindtap="handleTraditionalLogin"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '账号登录'}}
    </button>
  </view>

  <!-- 切换传统登录 -->
  <view class="switch-login" wx:if="{{!showTraditionalLogin}}" bindtap="toggleTraditionalLogin">
    <text>使用账号密码登录</text>
  </view>
  <view class="switch-login" wx:else bindtap="toggleTraditionalLogin">
    <text>使用微信登录</text>
  </view>
</view>