/* 页面整体样式 */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-top: 140rpx;
  margin-bottom: 120rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.app-name {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.app-slogan {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 微信登录区域 */
.wechat-login-section {
  width: 100%;
  margin-bottom: 60rpx;
}

.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  background: #07c160;
  border: none;
  border-radius: 48rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
  transition: all 0.3s ease;
  padding: 0;
  margin: 0;
  line-height: 96rpx;
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.wechat-login-btn.loading {
  background: #58b98c;
  box-shadow: none;
}

.wechat-icon {
  width: 44rpx;
  height: 44rpx;
}

.login-tip {
  text-align: center;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.login-tip .link {
  color: #ffffff;
  text-decoration: underline;
}

/* 分割线 */
.divider {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.3);
}

.divider-text {
  padding: 0 20rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 传统登录区域 */
.traditional-login-section {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 40rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.input-wrapper {
  position: relative;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  border: 2rpx solid transparent;
}

.input-icon {
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #6c757d;
  z-index: 1;
}

.input-field {
  width: 100%;
  height: 44rpx;
  padding-left: 60rpx;
  font-size: 30rpx;
  color: #212529;
  background: transparent;
  border: none;
  outline: none;
}

.input-field::placeholder {
  color: #6c757d;
  font-size: 26rpx;
}

.traditional-login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  margin-top: 20rpx;
}

.traditional-login-btn:active {
  transform: translateY(2rpx);
}

.traditional-login-btn.loading {
  background: #6c757d;
  box-shadow: none;
}

/* 切换登录方式 */
.switch-login {
  margin-top: 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-decoration: underline;
}