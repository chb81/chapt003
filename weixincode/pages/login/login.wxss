/* 页面整体样式 */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-top: 100rpx;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.app-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.app-slogan {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单区域 */
.form-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 60rpx;
}

.form-group {
  margin-bottom: 40rpx;
}

.input-wrapper {
  position: relative;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input-wrapper.focused {
  background: #ffffff;
  border-color: #667eea;
  box-shadow: 0 0 0 6rpx rgba(102, 126, 234, 0.1);
}

.input-icon {
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #6c757d;
  z-index: 1;
}

.input-field {
  width: 100%;
  height: 44rpx;
  padding-left: 60rpx;
  font-size: 30rpx;
  color: #212529;
  background: transparent;
  border: none;
  outline: none;
}

.input-field::placeholder {
  color: #6c757d;
  font-size: 26rpx;
}

/* 验证码输入框 */
.captcha-input {
  width: 50%;
}

.captcha-image {
  width: 180rpx;
  height: 60rpx;
  border-radius: 8rpx;
  margin-left: 20rpx;
}

/* 表单选项 */
.form-options {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 50rpx;
}

.remember-password {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #495057;
}

.checkbox {
  margin-right: 10rpx;
  color: #dee2e6;
}

.checkbox.checked {
  color: #667eea;
}

.forgot-password {
  font-size: 28rpx;
  color: #667eea;
}

.forgot-password text {
  color: #667eea;
}

/* 按钮样式 */
.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.login-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.login-btn.loading {
  background: #6c757d;
  box-shadow: none;
}

/* 微信登录 */
.wechat-login {
  margin-top: 30rpx;
  text-align: center;
}

.wechat-btn {
  background: #ffffff;
  border: 2rpx solid #dee2e6;
  border-radius: 16rpx;
  padding: 20rpx 40rpx;
  color: #212529;
  font-size: 28rpx;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.wechat-btn:active {
  background: #f8f9fa;
}

.wechat-icon {
  color: #1aad19;
}

/* 底部区域 */
.bottom-section {
  text-align: center;
  margin-bottom: 100rpx;
}

.bottom-section text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.register-link {
  color: #ffffff;
  font-weight: bold;
  margin-left: 10rpx;
  text-decoration: underline;
}

/* 响应式适配 */
@media (max-width: 750rpx) {
  .login-container {
    padding: 30rpx 20rpx;
  }
  
  .logo-section {
    margin-top: 60rpx;
    margin-bottom: 60rpx;
  }
  
  .form-section {
    padding: 40rpx 30rpx;
  }
  
  .logo {
    width: 120rpx;
    height: 120rpx;
  }
  
  .app-name {
    font-size: 36rpx;
  }
  
  .app-slogan {
    font-size: 24rpx;
  }
  
  .login-btn {
    height: 80rpx;
    font-size: 30rpx;
  }
}