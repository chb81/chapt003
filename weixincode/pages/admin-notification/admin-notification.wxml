<view class="container">
  <view class="header"><text class="title">通知管理</text></view>
  <view class="action-bar">
    <view class="action-btn primary" bindtap="onSendAll"><text>发送全员通知</text></view>
  </view>
  <view class="list" wx:if="{{items.length > 0}}">
    <view class="card" wx:for="{{items}}" wx:key="id">
      <view class="card-header">
        <text class="card-title">{{item.title}}</text>
        <text class="type-tag">{{item.type}}</text>
      </view>
      <view class="card-body">
        <view class="info-row"><text class="label">内容：</text><text class="value">{{item.content}}</text></view>
        <view class="info-row"><text class="label">时间：</text><text class="value">{{item.createdAt}}</text></view>
      </view>
    </view>
  </view>
  <view class="empty" wx:if="{{!loading && items.length === 0}}"><text>暂无通知</text></view>
  <view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>
  <view class="pagination" wx:if="{{totalPages > 1}}">
    <view class="page-btn" bindtap="onPrevPage" style="opacity: {{currentPage > 0 ? 1 : 0.5}}"><text>上一页</text></view>
    <text class="page-info">{{currentPage + 1}} / {{totalPages}}</text>
    <view class="page-btn" bindtap="onNextPage" style="opacity: {{currentPage < totalPages - 1 ? 1 : 0.5}}"><text>下一页</text></view>
  </view>
  <view class="modal-mask" wx:if="{{showForm}}" bindtap="onCancelForm"></view>
  <view class="modal" wx:if="{{showForm}}">
    <view class="modal-header">
      <text class="modal-title">发送通知</text>
      <text class="modal-close" bindtap="onCancelForm">✕</text>
    </view>
    <scroll-view scroll-y class="modal-body">
      <view class="form-group"><text class="form-label">标题 *</text><input class="form-input" placeholder="通知标题" value="{{formData.title}}" bindinput="onFormInput" data-field="title" /></view>
      <view class="form-group"><text class="form-label">类型</text>
        <picker range="{{types}}" value="{{typeIndex}}" bindchange="onTypeChange">
          <view class="form-input picker-val"><text>{{formData.type}}</text><text class="arrow">▼</text></view>
        </picker>
      </view>
      <view class="form-group"><text class="form-label">内容 *</text><textarea class="form-textarea" placeholder="通知内容" value="{{formData.content}}" bindinput="onFormInput" data-field="content" auto-height maxlength="-1" /></view>
      <view class="form-group"><text class="form-label">链接(可选)</text><input class="form-input" placeholder="点击跳转链接" value="{{formData.link}}" bindinput="onFormInput" data-field="link" /></view>
    </scroll-view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="onCancelForm">取消</view>
      <view class="modal-btn confirm" bindtap="onConfirmSend">发送</view>
    </view>
  </view>
</view>
