.projects-container {
  min-height: 100vh;
  background: #f5f7fa;
}

.search-section {
  background: #ffffff;
  padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  margin-right: 16rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-btn {
  background: #1989fa;
  color: #ffffff;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.filter-section {
  background: #ffffff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
}

.filter-scroll {
  display: flex;
  white-space: nowrap;
  padding: 0 30rpx;
}

.filter-item {
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  background: #f5f7fa;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.filter-item.active {
  background: #1989fa;
  color: #ffffff;
}

.advanced-filter {
  background: #ffffff;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-row:last-child {
  border-bottom: none;
}

.filter-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333;
}

.filter-picker {
  flex: 1;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.filter-input {
  flex: 1;
  font-size: 28rpx;
}

.projects-list {
  padding: 20rpx 30rpx;
}

.project-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.project-image {
  position: relative;
  height: 320rpx;
  width: 100%;
}

.project-image image {
  width: 100%;
  height: 100%;
}

.project-status {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  background: #07c160;
  color: #ffffff;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.project-content {
  padding: 24rpx;
}

.project-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-category {
  display: inline-block;
  background: #f0f9ff;
  color: #1989fa;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.project-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  margin-right: 32rpx;
}

.info-item icon {
  margin-right: 8rpx;
}

.project-location {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.project-location icon {
  margin-right: 8rpx;
}

.project-actions {
  display: flex;
  justify-content: flex-end;
}

.apply-btn {
  background: #1989fa;
  color: #ffffff;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
}

.view-btn {
  background: #f5f7fa;
  color: #666;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #1989fa;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: #999;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.project-modal {
  width: 640rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-icon {
  color: #999;
}

.modal-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.detail-section {
  margin-bottom: 32rpx;
}

.detail-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.detail-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.detail-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
}

.item-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.item-value {
  font-size: 28rpx;
  color: #333;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 32rpx;
  border-top: 1rpx solid #e8e8e8;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  background: #f5f7fa;
  color: #666;
}

.modal-btn.primary {
  background: #1989fa;
  color: #ffffff;
}

.modal-btn.disabled {
  background: #ccc;
  color: #999;
}

.apply-modal {
  width: 640rpx;
  max-height: 85vh;
  background: #ffffff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #f9f9f9;
}

.form-counter {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}