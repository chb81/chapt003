<view class="projects-container">
  <view class="search-section">
    <view class="search-bar">
      <icon class="search-icon" type="search" size="16"></icon>
      <input 
        class="search-input" 
        type="text" 
        placeholder="搜索学校名称" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
      />
      <view class="search-btn" bindtap="onSearchConfirm">搜索</view>
    </view>
  </view>

  <view class="filter-section">
    <scroll-view class="filter-scroll" scroll-x enable-flex>
      <view 
        class="filter-item {{activeTab === 'all' ? 'active' : ''}}" 
        bindtap="clearFilters"
      >
        全部
      </view>
      <view 
        wx:for="{{schoolTypes}}" 
        wx:key="value"
        class="filter-item {{activeTab === item.value ? 'active' : ''}}" 
        bindtap="onTypeChange"
        data-value="{{item.value}}"
      >
        {{item.label}}
      </view>
    </scroll-view>
  </view>

  <view class="advanced-filter">
    <view class="filter-row">
      <view class="filter-label">城市</view>
      <picker 
        class="filter-picker"
        range="{{cities}}" 
        bindchange="onCityChange"
      >
        <view class="picker-value">
          {{filters.city || '请选择城市'}}
        </view>
      </picker>
    </view>
    
    <view wx:if="{{districts.length > 0}}" class="filter-row">
      <view class="filter-label">区县</view>
      <picker 
        class="filter-picker"
        range="{{districts}}" 
        bindchange="onDistrictChange"
      >
        <view class="picker-value">
          {{filters.district || '请选择区县'}}
        </view>
      </picker>
    </view>
  </view>

  <view class="schools-list">
    <view 
      wx:for="{{schools}}" 
      wx:key="id" 
      class="school-card"
      bindtap="showSchoolDetail"
      data-id="{{item.id}}"
    >
      <view class="school-content">
        <view class="school-header">
          <view class="school-name">{{item.name}}</view>
          <view class="school-type-badge">{{getSchoolTypeLabel(item.type)}}</view>
        </view>
        <view class="school-info">
          <text class="info-item">{{item.city || ''}}</text>
          <text wx:if="{{item.district}}" class="info-item">{{item.district}}</text>
        </view>
        <view wx:if="{{item.admissionScoreYear1}}" class="school-scores">
          <text class="score-item">近年分数线: {{item.admissionScoreYear1}}</text>
        </view>
        <view wx:if="{{item.enrollmentQuota}}" class="school-quota">
          <text class="quota-text">招生计划: {{item.enrollmentQuota}}人</text>
        </view>
      </view>
    </view>

    <view wx:if="{{schools.length === 0 && !loading}}" class="empty-state">
      <view class="empty-text">暂无学校数据</view>
    </view>

    <view wx:if="{{loading}}" class="loading-state">
      <view class="loading-spinner"></view>
      <view class="loading-text">加载中...</view>
    </view>

    <view wx:if="{{hasMore && !loading}}" class="load-more" bindtap="loadMoreSchools">
      <text>加载更多</text>
    </view>
    <view wx:if="{{!hasMore && schools.length > 0}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </view>
</view>

<view wx:if="{{showDetailModal}}" class="modal-mask" bindtap="hideDetailModal">
  <view class="detail-modal" catchtap="">
    <view class="modal-header">
      <view class="modal-title">{{currentSchool.name || '学校详情'}}</view>
      <icon class="close-icon" type="clear" size="20" bindtap="hideDetailModal"></icon>
    </view>
    
    <scroll-view class="modal-body" scroll-y>
      <view class="detail-section">
        <view class="detail-label">学校类型</view>
        <view class="detail-content">{{getSchoolTypeLabel(currentSchool.type)}}</view>
      </view>
      
      <view class="detail-section">
        <view class="detail-label">所在地区</view>
        <view class="detail-content">{{currentSchool.city}} {{currentSchool.district}}</view>
      </view>
      
      <view wx:if="{{currentSchool.address}}" class="detail-section">
        <view class="detail-label">地址</view>
        <view class="detail-content">{{currentSchool.address}}</view>
      </view>
      
      <view wx:if="{{currentSchool.phone}}" class="detail-section">
        <view class="detail-label">联系电话</view>
        <view class="detail-content">{{currentSchool.phone}}</view>
      </view>

      <view wx:if="{{currentSchool.admissionScoreYear1}}" class="detail-section">
        <view class="detail-label">历年分数线</view>
        <view class="detail-content">
          <text>前年: {{currentSchool.admissionScoreYear3 || '-'}}</text>
          <text>去年: {{currentSchool.admissionScoreYear2 || '-'}}</text>
          <text>今年: {{currentSchool.admissionScoreYear1 || '-'}}</text>
        </view>
      </view>

      <view wx:if="{{currentSchool.enrollmentQuota}}" class="detail-section">
        <view class="detail-label">招生计划</view>
        <view class="detail-content">{{currentSchool.enrollmentQuota}}人</view>
      </view>

      <view wx:if="{{currentSchool.features}}" class="detail-section">
        <view class="detail-label">学校特色</view>
        <view class="detail-content">{{currentSchool.features}}</view>
      </view>

      <view wx:if="{{currentSchool.description}}" class="detail-section">
        <view class="detail-label">学校简介</view>
        <view class="detail-content">{{currentSchool.description}}</view>
      </view>

      <view wx:if="{{admissionProbability}}" class="detail-section">
        <view class="detail-label">录取概率</view>
        <view class="detail-content probability">{{admissionProbability.probabilityPercent || '--'}}%</view>
        <view wx:if="{{admissionProbability.suggestion}}" class="detail-sub">{{admissionProbability.suggestion}}</view>
      </view>
    </scroll-view>
  </view>
</view>
