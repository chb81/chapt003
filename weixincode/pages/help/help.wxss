page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #e8e8e8;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #1989fa;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1989fa;
  border-radius: 2rpx;
}

.content {
  flex: 1;
  overflow-y: auto;
}

.faq-section {
  padding: 30rpx;
}

.faq-item {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: #fff;
}

.question-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-right: 20rpx;
}

.expand-icon {
  font-size: 20rpx;
  color: #999;
  transition: transform 0.3s;
  flex-shrink: 0;
}

.expand-icon.expanded {
  transform: rotate(180deg);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease-out;
  background: #fafafa;
}

.faq-answer.expanded {
  max-height: 1000rpx;
  padding: 30rpx;
}

.faq-answer text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.contact-tip {
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
  padding: 40rpx 30rpx;
  border-radius: 12rpx;
  text-align: center;
  margin-top: 40rpx;
}

.tip-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1989fa;
  margin-bottom: 12rpx;
}

.tip-content {
  font-size: 26rpx;
  color: #0050b3;
  margin-bottom: 24rpx;
}

.contact-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
}

.feedback-section {
  padding: 30rpx;
}

.form-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item-select {
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
}

.select-value {
  font-size: 28rpx;
  color: #333;
}

.select-arrow {
  font-size: 20rpx;
  color: #999;
}

.form-input {
  width: 100%;
  font-size: 28rpx;
  padding: 20rpx 0;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.add-icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

.submit-section {
  margin-top: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn[disabled] {
  background: #ccc;
}
