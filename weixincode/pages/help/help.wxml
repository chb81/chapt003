<view class="container">
  <view class="tabs">
    <view 
      class="tab-item {{activeTab === item.key ? 'active' : ''}}" 
      wx:for="{{tabs}}" 
      wx:key="key"
      bindtap="switchTab"
      data-tab="{{item.key}}"
    >
      {{item.label}}
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <view class="faq-section" wx:if="{{activeTab === 'faq'}}">
      <view class="faq-item" wx:for="{{faqList}}" wx:key="question">
        <view class="faq-question" bindtap="toggleFaq" data-index="{{index}}">
          <view class="question-text">{{item.question}}</view>
          <view class="expand-icon {{expandedFaqIndex === index ? 'expanded' : ''}}">▼</view>
        </view>
        <view class="faq-answer {{expandedFaqIndex === index ? 'expanded' : ''}}" wx:if="{{expandedFaqIndex === index}}">
          <text>{{item.answer}}</text>
        </view>
      </view>
      
      <view class="contact-tip">
        <view class="tip-title">还有问题？</view>
        <view class="tip-content">切换到"意见反馈"页面，告诉我们您的问题</view>
        <view class="contact-btn" bindtap="handleContact">联系客服</view>
      </view>
    </view>

    <view class="feedback-section" wx:if="{{activeTab === 'feedback'}}">
      <view class="form-section">
        <view class="form-title">反馈类型</view>
        <view class="form-item form-item-select" bindtap="showTypePicker">
          <view class="select-value">{{feedbackForm.type}}</view>
          <view class="select-arrow">▼</view>
        </view>
      </view>

      <view class="form-section">
        <view class="form-title">反馈内容 <text class="required">*</text></view>
        <textarea 
          class="form-textarea" 
          placeholder="请详细描述您的问题或建议（至少10个字）"
          value="{{feedbackForm.content}}"
          bindinput="handleContentInput"
          maxlength="500"
          show-confirm-bar="{{false}}"
        ></textarea>
        <view class="char-count">{{feedbackForm.content.length}}/500</view>
      </view>

      <view class="form-section">
        <view class="form-title">联系方式（选填）</view>
        <input 
          class="form-input" 
          placeholder="手机号或邮箱，方便我们联系您"
          value="{{feedbackForm.contact}}"
          bindinput="handleContactInput"
        />
      </view>

      <view class="form-section">
        <view class="form-title">上传图片（选填，最多3张）</view>
        <view class="image-list">
          <view class="image-item" wx:for="{{feedbackForm.images}}" wx:key="*this" bindtap="previewImage" data-index="{{index}}">
            <image src="{{item}}" mode="aspectFill"></image>
            <view class="remove-btn" catchtap="removeImage" data-index="{{index}}">×</view>
          </view>
          <view class="image-add" wx:if="{{feedbackForm.images.length < 3}}" bindtap="chooseImage">
            <view class="add-icon">+</view>
            <view class="add-text">添加图片</view>
          </view>
        </view>
      </view>

      <view class="submit-section">
        <button class="submit-btn" bindtap="submitFeedback" disabled="{{submitting}}">
          {{submitting ? '提交中...' : '提交反馈'}}
        </button>
      </view>
    </view>
  </scroll-view>
</view>
