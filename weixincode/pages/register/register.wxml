<view class="container">
  <view class="header">
    <text class="title">注册账号</text>
  </view>
  
  <view class="form">
    <view class="form-item">
      <input class="input" placeholder="请输入手机号" type="number" />
    </view>
    
    <view class="form-item">
      <input class="input" placeholder="请输入验证码" type="text" />
      <button class="verify-btn">获取验证码</button>
    </view>
    
    <view class="form-item">
      <input class="input" placeholder="请输入密码" password />
    </view>
    
    <view class="form-item">
      <input class="input" placeholder="请确认密码" password />
    </view>
    
    <button class="register-btn">注册</button>
    
    <text class="login-link" bindtap="goToLogin">已有账号？返回登录</text>
  </view>
</view>