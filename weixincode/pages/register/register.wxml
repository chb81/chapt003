<view class="container">
  <!-- 步骤一：微信授权 -->
  <view class="authorize-section" wx:if="{{step === 'authorize'}}">
    <view class="header">
      <text class="title">微信授权</text>
      <text class="subtitle">授权微信账号快速创建您的档案</text>
    </view>

    <view class="auth-card">
      <image class="wechat-logo" src="/images/wechat-icon.png" mode="aspectFit"></image>
      <text class="auth-desc">点击下方按钮，授权微信登录</text>

      <button 
        class="auth-btn {{loading ? 'loading' : ''}}" 
        bindtap="handleWechatLogin"
        disabled="{{loading}}"
      >
        {{loading ? '授权中...' : '微信授权登录'}}
      </button>
    </view>
  </view>

  <!-- 步骤二：完善资料 -->
  <view class="profile-section" wx:if="{{step === 'profile'}}">
    <view class="header">
      <text class="title">完善个人资料</text>
      <text class="subtitle">帮助我们为您提供更好的服务</text>
    </view>
    
    <view class="form">
      <view class="form-item">
        <text class="label">昵称</text>
        <input 
          class="input" 
          placeholder="请输入昵称" 
          value="{{form.nickname}}"
          data-field="nickname"
          bindinput="onInputChange"
        />
      </view>
      
      <view class="form-item">
        <text class="label">手机号</text>
        <input 
          class="input" 
          placeholder="请输入手机号（选填）" 
          type="number"
          value="{{form.phone}}"
          data-field="phone"
          bindinput="onInputChange"
        />
      </view>

      <view class="form-item">
        <text class="label">性别</text>
        <picker mode="selector" range="['男','女']" bindchange="onGenderChange">
          <view class="picker-value">{{form.gender || '请选择'}}</view>
        </picker>
      </view>
    </view>
    
    <button class="submit-btn" bindtap="handleSubmitProfile" disabled="{{loading}}">
      {{loading ? '保存中...' : '完成'}}
    </button>

    <view class="skip-link" bindtap="skipProfile">
      <text>跳过，稍后完善</text>
    </view>
  </view>
</view>