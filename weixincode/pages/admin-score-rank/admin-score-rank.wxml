<view class="container">
  <view class="header">
    <text class="title">分数位次数据管理</text>
  </view>

  <view class="filter-bar">
    <input class="filter-input" placeholder="城市" value="{{filterCity}}" bindinput="onCityInput" />
    <picker mode="number" range="{{yearRange}}" value="{{yearIndex}}" bindchange="onYearChange">
      <view class="filter-item">
        <text>{{filterYear ? filterYear + '年' : '年度'}}</text>
        <text class="arrow">▼</text>
      </view>
    </picker>
    <view class="filter-btn" bindtap="onSearch">
      <text>搜索</text>
    </view>
  </view>

  <view class="action-bar">
    <view class="action-btn primary" bindtap="onAdd">
      <text>+ 新增数据</text>
    </view>
  </view>

  <view class="list" wx:if="{{scoreRanks.length > 0}}">
    <view class="card" wx:for="{{scoreRanks}}" wx:key="id">
      <view class="card-header">
        <text class="score-val">{{item.totalScore}}分</text>
        <text class="rank-tag">全市第{{item.cityRank}}名</text>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="label">城市：</text>
          <text class="value">{{item.city}}</text>
        </view>
        <view class="info-row">
          <text class="label">年度：</text>
          <text class="value">{{item.year}}年</text>
        </view>
        <view class="info-row" wx:if="{{item.district}}">
          <text class="label">区县：</text>
          <text class="value">{{item.district}}</text>
        </view>
        <view class="info-row" wx:if="{{item.districtRank}}">
          <text class="label">区内排名：</text>
          <text class="value">{{item.districtRank}}</text>
        </view>
        <view class="info-row" wx:if="{{item.studentCount}}">
          <text class="label">同分人数：</text>
          <text class="value highlight">{{item.studentCount}}</text>
        </view>
        <view class="info-row" wx:if="{{item.cumulativeCount}}">
          <text class="label">累计人数：</text>
          <text class="value">{{item.cumulativeCount}}</text>
        </view>
      </view>
      <view class="card-actions">
        <view class="btn-edit" bindtap="onEdit" data-item="{{item}}">编辑</view>
        <view class="btn-delete" bindtap="onDelete" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && scoreRanks.length === 0}}">
    <text>暂无分数位次数据</text>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="pagination" wx:if="{{totalPages > 1}}">
    <view class="page-btn" bindtap="onPrevPage" style="opacity: {{currentPage > 0 ? 1 : 0.5}}">
      <text>上一页</text>
    </view>
    <text class="page-info">{{currentPage + 1}} / {{totalPages}}</text>
    <view class="page-btn" bindtap="onNextPage" style="opacity: {{currentPage < totalPages - 1 ? 1 : 0.5}}">
      <text>下一页</text>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showForm}}" bindtap="onCancelForm"></view>
  <view class="modal" wx:if="{{showForm}}">
    <view class="modal-header">
      <text class="modal-title">{{editingId ? '编辑数据' : '新增数据'}}</text>
      <text class="modal-close" bindtap="onCancelForm">✕</text>
    </view>
    <scroll-view scroll-y class="modal-body">
      <view class="form-group">
        <text class="form-label">城市 *</text>
        <input class="form-input" placeholder="如：武汉" value="{{formData.city}}" bindinput="onFormInput" data-field="city" />
      </view>
      <view class="form-group">
        <text class="form-label">年度 *</text>
        <input class="form-input" type="number" placeholder="如2025" value="{{formData.year}}" bindinput="onFormInput" data-field="year" />
      </view>
      <view class="form-group">
        <text class="form-label">中考总分 *</text>
        <input class="form-input" type="digit" placeholder="输入总分" value="{{formData.totalScore}}" bindinput="onFormInput" data-field="totalScore" />
      </view>
      <view class="form-group">
        <text class="form-label">全市排名 *</text>
        <input class="form-input" type="number" placeholder="输入排名" value="{{formData.cityRank}}" bindinput="onFormInput" data-field="cityRank" />
      </view>
      <view class="form-group">
        <text class="form-label">区县</text>
        <input class="form-input" placeholder="输入区县（可选）" value="{{formData.district}}" bindinput="onFormInput" data-field="district" />
      </view>
      <view class="form-group">
        <text class="form-label">区内排名</text>
        <input class="form-input" type="number" placeholder="输入区内排名" value="{{formData.districtRank}}" bindinput="onFormInput" data-field="districtRank" />
      </view>
      <view class="form-group">
        <text class="form-label">同分人数</text>
        <input class="form-input" type="number" placeholder="该分数段人数" value="{{formData.studentCount}}" bindinput="onFormInput" data-field="studentCount" />
      </view>
      <view class="form-group">
        <text class="form-label">累计人数</text>
        <input class="form-input" type="number" placeholder="从高到低累计人数" value="{{formData.cumulativeCount}}" bindinput="onFormInput" data-field="cumulativeCount" />
      </view>
    </scroll-view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="onCancelForm">取消</view>
      <view class="modal-btn confirm" bindtap="onSaveForm">保存</view>
    </view>
  </view>
</view>
